{
  "name": "elifoot-rebuild",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=verbose && vite build",
    "test:series": "bash scripts/debug-bug.sh series",
    "test:regression": "vitest run tests/regression",
    "test:specs": "vitest run tests/specs",
    "bug:search": "bash scripts/debug-bug.sh search",
    "bug:ticket": "bash scripts/debug-bug.sh ticket",
    "bug:fix": "bash scripts/debug-bug.sh fix",
    "bug:test": "bash scripts/debug-bug.sh test",
    "bug:full": "bash scripts/debug-bug.sh full",
    "mutate": "stryker run",
    "mutate:report": "open tests/characterization/stryker-report/index.html"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
