{
  "_meta": {
    "name": "OléFUT ISSSD-Premium 32-bit Design Tokens",
    "version": "1.0",
    "source": "docs/brand-guidelines.md v1.1",
    "description": "Three-layer token architecture: Primitive (raw values) → Semantic (purpose) → Component (specific use)",
    "lastUpdated": "2026-05-13"
  },
  "primitive": {
    "colors": {
      "green": {
        "neon": "#39FF14",
        "pitch": "#52B788",
