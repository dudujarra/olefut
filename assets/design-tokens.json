      "lineHeights": {
        "tight": 1.0,
        "close": 1.2,
        "normal": 1.25,
        "relaxed": 1.3,
        "loose": 1.4,
        "spacious": 1.5
      },
      "letterSpacing": {
        "tighter": "-0.02em",
        "tight": "-0.01em",
        "normal": "0",
